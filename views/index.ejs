<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AgentNTFY - Dashboard</title>
    <style>
        :root {
            --bg-color: #050505;
            --sidebar-bg: #080808;
            --card-bg: #0a0a0a;
            --text-color: #d4d4d4;
            --accent-color: #4af626;
            --border-color: #1a1a1a;
            --active-bg: rgba(74, 246, 38, 0.05);
        }

        * {
            box-sizing: border-box;
            user-select: none;
        }

        body,
        html {
            height: 100%;
            width: 100%;
            margin: 0;
            padding: 0;
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: "Courier New", Courier, monospace;
            display: flex;
            overflow: hidden;
        }

        /* Sidebar */
        .sidebar {
            width: 200px;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            padding: 1.5rem 1rem;
            position: relative;
            z-index: 20;
        }

        .sidebar::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(rgba(255, 255, 255, 0.005) 50%, rgba(0, 0, 0, 0.02) 50%);
            background-size: 100% 4px;
            pointer-events: none;
        }

        .sidebar-brand {
            font-size: 0.6rem;
            color: #333;
            letter-spacing: 0.15rem;
            margin-bottom: 2rem;
            text-transform: uppercase;
        }

        .sidebar-nav {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .nav-item {
            padding: 0.6rem 1rem;
            color: #555;
            text-decoration: none;
            border: 1px solid transparent;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.8rem;
            letter-spacing: 0.04rem;
        }

        .nav-item:hover {
            color: var(--text-color);
            background: rgba(255, 255, 255, 0.01);
            transform: translateX(3px);
        }

        .nav-item.active {
            color: var(--accent-color);
            border-color: rgba(74, 246, 38, 0.3);
            background: var(--active-bg);
        }

        /* Main Container */
        .main-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        /* Navbar */
        .navbar {
            height: 50px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-color);
        }

        .navbar-logo {
            letter-spacing: 0.3rem;
            text-transform: uppercase;
            font-size: 0.9rem;
            font-weight: bold;
            color: var(--text-color);
            opacity: 0.9;
        }

        /* Dashboard Content */
        .content {
            flex: 1;
            padding: 2rem;
            display: flex;
            flex-wrap: wrap;
            align-content: flex-start;
            gap: 1rem;
            position: relative;
            z-index: 5;
        }

        .content::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(rgba(255, 255, 255, 0.01) 50%, rgba(0, 0, 0, 0.05) 50%);
            background-size: 100% 4px;
            pointer-events: none;
            z-index: 10;
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            padding: 1rem;
            flex: 1;
            min-width: 200px;
            height: 130px;
            text-align: center;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
            transition: all 0.3s ease;
        }

        .card:hover {
            border-color: #333;
            background: rgba(255, 255, 255, 0.01);
            transform: translateY(-5px);
        }

        .card-label {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 0.1rem;
            color: #555;
            margin-bottom: 0.75rem;
        }

        .card-value {
            font-size: 2.5rem;
            color: var(--text-color);
            transition: all 0.3s;
        }

        .card:hover .card-value {
            color: var(--accent-color);
            text-shadow: 0 0 15px rgba(74, 246, 38, 0.3);
        }

        /* Scanline Overlay */
        .scanline {
            width: 100%;
            height: 100px;
            z-index: 15;
            background: linear-gradient(0deg, rgba(0, 0, 0, 0) 0%, rgba(255, 255, 255, 0.01) 50%, rgba(0, 0, 0, 0) 100%);
            opacity: 0.1;
            position: absolute;
            bottom: 100%;
            animation: scanline 8s linear infinite;
            pointer-events: none;
        }

        .purge-container {
            width: 100%;
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin-top: 2rem;
            position: relative;
            z-index: 20;
        }

        .btn-purge {
            background: none;
            border: 1px solid #ff3b3b;
            color: #ff3b3b;
            padding: 0.8rem 1.5rem;
            cursor: pointer;
            font-family: inherit;
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 0.1rem;
            transition: all 0.3s;
            text-decoration: none;
        }

        .btn-purge:hover {
            background: rgba(255, 59, 59, 0.05);
            box-shadow: 0 0 20px rgba(255, 59, 59, 0.1);
            border-color: #ff5555;
            color: #ff5555;
        }

        @keyframes scanline {
            0% {
                bottom: 100%;
            }

            100% {
                bottom: -100px;
            }
        }
    </style>
</head>

<body>
    <div class="scanline"></div>

    <aside class="sidebar">
        <div class="sidebar-brand">> SIDEBAR</div>
        <nav class="sidebar-nav">
            <a href="/" class="nav-item active">DASHBOARD</a>
            <a href="/agents" class="nav-item">AGENTS</a>
        </nav>
    </aside>

    <main class="main-container">
        <header class="navbar">
            <div class="navbar-logo">AgentNTFY</div>
        </header>

        <section class="content">
            <div class="purge-container">
                <a href="/?purge=agents" class="btn-purge" onclick='return confirm("Are you sure you want to permanently delete all records of all agents?")'>Purge all agents</a>
                <a href="/?purge=messages" class="btn-purge" onclick='return confirm("Are you sure you want to permanently delete all messages sent to agents?")'>Purge all messages</a>
            </div>

            <div class="card">
                <div class="card-label">Agents</div>
                <div class="card-value">
                    <%= agentsCount %>
                </div>
            </div>

            <div class="card">
                <div class="card-label">Concealment Messages</div>
                <div class="card-value">
                    <%= messagesCount %>
                </div>
            </div>
        </section>
    </main>

    <script>
        // Subtle interaction: card values counting up
        document.addEventListener("DOMContentLoaded", () => {
            const values = document.querySelectorAll(".card-value")
            values.forEach(val => {
                const target = parseInt(val.textContent)
                if (isNaN(target)) return

                let current = 0
                const duration = 1000
                const step = target / (duration / 16)

                const update = () => {
                    current += step
                    if (current >= target) {
                        val.textContent = target
                    } else {
                        val.textContent = Math.floor(current)
                        requestAnimationFrame(update)
                    }
                }

                val.textContent = "0"
                setTimeout(update, 500)
            })
        })
    </script>
</body>

</html>